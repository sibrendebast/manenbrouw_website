generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Product {
  id          String      @id @default(uuid())
  slug        String      @unique
  name        String
  style       String?
  abv         String?
  volume      String?
  price       Float
  description String
  images      String
  inStock     Boolean     @default(true)
  stockCount  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  btwCategory Int?        @default(21)
  isHidden    Boolean     @default(false)
  category    ProductType @default(BEER)
  OrderItem   OrderItem[]
}

model Order {
  id              String        @id @default(uuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  shippingMethod  String
  totalAmount     Float
  status          String        @default("pending")
  stripeSessionId String?
  paymentMethod   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  invoiceUrl      String?
  orderNumber     String?       @unique
  locale          String        @default("nl")
  comment         String?
  tickets         EventTicket[]
  items           OrderItem[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  quantity    Int
  price       Float
  btwCategory Int?    @default(21)
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  firstName String?
  lastName  String?
}

model Event {
  id                   String        @id @default(uuid())
  title                String
  description          String
  date                 DateTime
  location             String
  isPaid               Boolean       @default(false)
  ticketPrice          Float?
  capacity             Int?
  ticketsSold          Int           @default(0)
  image                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  isHidden             Boolean       @default(false)
  earlyBirdEndDate     DateTime?
  earlyBirdPrice       Float?
  ticketSalesStartDate DateTime?
  tickets              EventTicket[]
}

model EventTicket {
  id          String   @id @default(uuid())
  eventId     String
  orderId     String?
  buyerName   String
  buyerEmail  String
  quantity    Int      @default(1)
  totalPrice  Float
  purchasedAt DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AdminUser {
  id                String             @id @default(uuid())
  username          String             @unique
  password          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id       String    @id @default(uuid())
  endpoint String
  keys     Json
  adminId  String
  admin    AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

/// Atomaire teller per kalenderjaar voor het genereren van brouwnummers (YYYY/NNN).
model RecipeSequence {
  jaar   Int @id
  teller Int @default(0)
}

model Recipe {
  id                      String             @id @default(uuid())
  brouwnummer             String             @unique
  naam                    String
  stijl                   String?
  notities                String?
  batchVolume             Float?
  brouwEfficiency         Float?
  attenuation             Float?
  ogCalc                  Float?
  fgCalc                  Float?
  abvCalc                 Float?
  platoCalc               Float?
  ibuCalc                 Float?
  ebcCalc                 Float?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  abvGemeten              Float?
  brouwefficientieGemeten Float?
  fgGemeten               Float?
  ogGemeten               Float?
  platoGemeten            Float?
  abvGevraagd             Float?
  fgGevraagd              Float?
  ogGevraagd              Float?
  platoGevraagd           Float?
  aantalBatches           Float?
  fermentatieStappen      FermentatieStap[]
  maischStappen           MaischStap[]
  ingredients             RecipeIngredient[]

  @@index([brouwnummer])
}

model RecipeIngredient {
  id               String         @id @default(uuid())
  recipeId         String
  stap             BrewingStap    @default(MAISCHEN)
  type             IngredientType @default(MOUT)
  naam             String
  hoeveelheid      Float
  eenheid          String
  extractPotential Float?
  kleurEbc         Float?
  alfazuur         Float?
  tijdMinuten      Int?
  volgorde         Int            @default(0)
  doseringGPerL    Float?
  lot              String?
  pelletOfBloem    String?
  tijdstip         String?
  recipe           Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

/// Maischstappen per recept (Protein Rest, Beta-Amylase, Alpha-Amylase, Mash Out).
model MaischStap {
  id       String @id @default(uuid())
  recipeId String
  stapNaam String
  tempC    Float?
  duurMin  Int?
  volgorde Int    @default(0)
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

/// Fermentatieschema-stappen per recept (hoofd, cold crash, …).
model FermentatieStap {
  id        String @id @default(uuid())
  recipeId  String
  stapNaam  String
  tempC     Float?
  duurDagen Int?
  volgorde  Int    @default(0)
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model CcpEntry {
  id         String   @id
  type       CcpType
  datum      DateTime
  lotnummer  String?
  uitgevoerd Boolean  @default(false)
  uitvoerder String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

model OngedierteInspectie {
  id                String   @id
  datum             DateTime
  verantwoordelijke String
  brouwcontainer    Boolean  @default(false)
  kelder            Boolean  @default(false)
  omgeving          Boolean  @default(false)
  afvalcontainer    Boolean  @default(false)
  opmerkingen       String?
  actie             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
}

model WerkregisterEntry {
  id                  String                @id
  datum               DateTime
  handeling           WerkregisterHandeling
  brouwaanvraagDatum  DateTime?
  brouwaanvraagNummer String?
  brouwnummer         String?
  volume              Float?
  fermentatievat      String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
}

enum ProductType {
  BEER
  GIFTBOX
  GLASS
  MERCH
}

enum BrewingStap {
  MAISCHEN
  KOKEN
  FERMENTATIE
  DRY_HOP
  CONDITIONING
  OVERIG
}

enum IngredientType {
  MOUT
  HOP
  GIST
  ANDERE
}

enum CcpType {
  GLASBREUK
  SCHIMMELVORMING
}

enum WerkregisterHandeling {
  BROUWEN
  OVERHEVELEN
  BOTTELEN_KEGGEN
  VERNIETIGING
}

// ─── Logboek — Werkregister ─────────────────────────────────────────────────

enum WerkregisterHandeling {
  BROUWEN
  OVERHEVELEN
  BOTTELEN_KEGGEN
  VERNIETIGING
}

model WerkregisterEntry {
  id                    String                  @id @default(uuid())
  datum                 DateTime                // Date of the action
  handeling             WerkregisterHandeling   // Type of action
  brouwaanvraagDatum    DateTime?               // Brouwaangifte date
  brouwaanvraagNummer   String?                 // e.g. "2025/009"
  brouwnummer           String?                 // e.g. "2025/009"
  volume                Float?                  // Volume in liters (optional)
  fermentatievat        String?                 // Fermentation vessel name

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}

// ─── Logboek — Ongediertebestrijdingsplan ───────────────────────────────────

model OngedierteInspectie {
  id                String   @id @default(uuid())
  datum             DateTime
  verantwoordelijke String              // Who performed the inspection
  brouwcontainer    Boolean  @default(false)
  kelder            Boolean  @default(false)
  omgeving          Boolean  @default(false)
  afvalcontainer    Boolean  @default(false)
  opmerkingen       String?             // Observations
  actie             String?             // Actions taken

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Logboek — CCP Tracker ──────────────────────────────────────────────────

enum CcpType {
  GLASBREUK
  SCHIMMELVORMING
}

model CcpEntry {
  id            String   @id @default(uuid())
  type          CcpType
  datum         DateTime
  lotnummer     String?             // e.g. "2025/007"
  uitgevoerd    Boolean  @default(false)
  uitvoerder    String?             // Who performed the check

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

